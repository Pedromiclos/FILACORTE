# Copie este arquivo para ".env" e ajuste os valores antes de subir em produção.

PORT=3000

# Segredo usado para assinar os tokens JWT. TROQUE isso em produção.
JWT_SECRET=troque-este-valor-por-uma-chave-secreta-longa-e-aleatoria

# Duração do token de sessão (em segundos). 604800 = 7 dias.
JWT_EXPIRES_IN=604800

# Credenciais do superadmin inicial (criadas automaticamente no primeiro start).
SUPERADMIN_EMAIL=admin@filacorte.com
SUPERADMIN_PASSWORD=troque-esta-senha

# ---------------------------------------------------------------------------
# Gateways de pagamento (opcional nesta fase — os endpoints em
# src/modules/payments.js já estão prontos para receber essas chaves).
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

MERCADOPAGO_ACCESS_TOKEN=

ASAAS_API_KEY=
